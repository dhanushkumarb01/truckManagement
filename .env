# ============================================
# Docker Environment Variables Template
# Smart Yard Monitoring System
# 
# Copy this file to .env.docker and fill in your values:
#   cp .env.docker.example .env.docker
# ============================================

# ============ Backend Configuration ============
NODE_ENV=production
PORT=5000

# MongoDB Connection
# For Docker Compose: use the service name
MONGODB_URI=mongodb+srv://dhanushkumarb:dhanushkumarb@cluster0.ijxwq9a.mongodb.net/truck-monitoring?retryWrites=true&w=majority&appName=Cluster0

# For MongoDB with authentication (optional):
# MONGODB_URI=mongodb://admin:password@mongo:27017/smartyard?authSource=admin

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# JWT Secret (generate a secure random string for production)
# JWT_SECRET=your-super-secret-jwt-key-change-in-production

# QR Code expiration in minutes
QR_EXPIRATION_MINUTES=15

# ============ MongoDB Configuration ============
# Optional: Enable MongoDB authentication
# MONGO_INITDB_ROOT_USERNAME=admin
# MONGO_INITDB_ROOT_PASSWORD=secure-mongo-password

# ============ Frontend Configuration ============
# API URL (relative path when using nginx proxy)
VITE_API_BASE_URL=/api
