# ============================================
# Docker Ignore - Backend
# Excludes unnecessary files from Docker build context
# ============================================

# Dependencies
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files (use Docker env vars instead)
.env
.env.local
.env.development
.env.production

# Git
.git
.gitignore

# IDE and Editor
.vscode
.idea
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Logs
logs
*.log

# Test files
coverage
.nyc_output
__tests__
*.test.js
*.spec.js

# Documentation
README.md
docs
*.md

# Build artifacts
dist
build
